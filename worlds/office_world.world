    </model>

    <model name="box3">
      <static>true</static>
      <pose>-3 -3 0.3 0 0 0</pose>
      <link name="link">
        <collision name="c">
          <geometry><box><size>0.7 0.7 0.6</size></box></geometry>
        </collision>
        <visual name="v">
          <geometry><box><size>0.7 0.7 0.6</size></box></geometry>
        </visual>
      </link>
    </model>

    <model name="box4">
      <static>true</static>
      <pose>3 -3 0.3 0 0 0</pose>
      <link name="link">
