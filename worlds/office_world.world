    <!-- ================= CYLINDERS ================= -->

    <model name="cylinder1">
      <static>true</static>
      <pose>1 -1 0.4 0 0 0</pose>
      <link name="link">
        <collision name="c">
          <geometry>
            <cylinder>
              <radius>0.25</radius>
              <length>0.8</length>
            </cylinder>
          </geometry>
        </collision>
        <visual name="v">
          <geometry>
            <cylinder>
              <radius>0.25</radius>
              <length>0.8</length>
            </cylinder>
          </geometry>
        </visual>
      </link>
    </model>

    <model name="cylinder2">
      <static>true</static>
      <pose>-1 2.5 0.4 0 0 0</pose>
      <link name="link">
        <collision name="c">
          <geometry>
            <cylinder>
              <radius>0.25</radius>
              <length>0.8</length>
            </cylinder>
          </geometry>
        </collision>
        <visual name="v">
          <geometry>
            <cylinder>
              <radius>0.25</radius>
              <length>0.8</length>
            </cylinder>
          </geometry>
        </visual>
      </link>
    </model>

    <!-- ================= TRAFFIC CONES ================= -->

    <model name="cone1">
      <static>true</static>
      <pose>2 -2 0.2 0 0 0</pose>
      <link name="link">
        <collision name="c">
          <geometry>
            <cylinder>
              <radius>0.12</radius>
              <length>0.4</length>
            </cylinder>
          </geometry>
        </collision>
        <visual name="v">
          <geometry>
            <cylinder>
              <radius>0.12</radius>
              <length>0.4</length>
            </cylinder>
          </geometry>
        </visual>
      </link>
    </model>

    <model name="cone2">
      <static>true</static>
      <pose>-2 0.5 0.2 0 0 0</pose>
      <link name="link">
        <collision name="c">
          <geometry>
            <cylinder>
              <radius>0.12</radius>
              <length>0.4</length>
            </cylinder>
          </geometry>
        </collision>
        <visual name="v">
          <geometry>
            <cylinder>
              <radius>0.12</radius>
              <length>0.4</length>
